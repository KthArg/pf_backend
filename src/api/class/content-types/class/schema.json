{
  "kind": "singleType",
  "collectionName": "classes",
  "info": {
    "singularName": "class",
    "pluralName": "classes",
    "displayName": "Class",
    "description": "The gym class offering"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "description": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "duration": {
      "type": "integer",
      "min": 1,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "level": {
      "type": "enumeration",
      "enum": ["beginner", "intermediate", "advanced", "all"],
      "default": "all",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "schedule": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "benefits": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "equipment": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    }
  }
}
